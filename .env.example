# =============================================================================
# Acca — Root .env.example
# =============================================================================
# This file documents environment variables for the whole project at a glance.
# In practice, each half loads its own:
#   - server/.env  (Postgres, Redis, JWT secret, API-Football key)
#   - client/src/environments/environment*.ts  (apiBaseUrl)
#
# Copy this file to .env if you want a single reference checked into git-ignore.
# Never commit a real .env.
# =============================================================================

# --- Postgres (used by docker-compose and by the backend) ---
POSTGRES_USER=acca
POSTGRES_PASSWORD=acca_dev_password
POSTGRES_DB=acca
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (used by docker-compose and by the backend) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Backend ---
# Generate a long random string for production. The dev value below is fine for local.
JWT_SECRET=change-me-in-production-this-is-a-dev-only-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:4200

# --- API-Football (https://www.api-football.com/) ---
# Sign up for a free key. Leave blank until you have one — health check still works.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- Logging ---
LOG_LEVEL=INFO
